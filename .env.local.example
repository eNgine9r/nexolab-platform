# The dashboard starts in demo mode until an operator explicitly selects live.
# Allowed values for the M3 adapter contract: demo | live
NEXT_PUBLIC_NEXOLAB_DATA_MODE=demo

# Required when NEXT_PUBLIC_NEXOLAB_DATA_MODE=live.
NEXT_PUBLIC_NEXOLAB_API_BASE_URL=http://127.0.0.1:8082
NEXT_PUBLIC_NEXOLAB_WEBSOCKET_URL=ws://127.0.0.1:8082/api/v1/telemetry/live
