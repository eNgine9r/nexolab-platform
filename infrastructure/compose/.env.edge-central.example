# Existing edge-01 production contract. Copy the actual stable adapter path
# from infrastructure/compose/.env.edge before running the cutover.
NEXOLAB_NODE_ID=edge-01
DEVICE_MODE=simulator
HARDWARE_DEVICE_MODE=modbus
RS485_HOST_DEVICE=/dev/serial/by-id/replace-with-stable-adapter-id
RS485_GROUP_GID=20
XJP60D_POINTS=106:3,106:4
XJP60D_SCALE=0.1
LE01MP_UNIT_IDS=200,201,202,203
SERIAL_TIMEOUT_SECONDS=0.30
SERIAL_RETRIES=1
MQTT_TOPIC=nexolab/telemetry
SAMPLE_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
DEVICE_AGENT_IMAGE=ghcr.io/engine9r/nexolab-device-agent:edge

# Trusted central host. Do not use a public or arbitrary interface while
# central Mosquitto is running without authentication.
CENTRAL_MQTT_HOST=192.168.1.10
CENTRAL_MQTT_PORT=1884
CENTRAL_MQTT_TOPIC=nexolab/telemetry
CENTRAL_BRIDGE_CLIENT_ID=nexolab-edge-01-bridge

# REST/WebSocket endpoints used by the validation script.
CENTRAL_API_BASE_URL=http://192.168.1.10:8082
CENTRAL_WEBSOCKET_URL=ws://192.168.1.10:8082/api/v1/telemetry/live
CUTOVER_MAX_SAMPLE_AGE_SECONDS=90
CUTOVER_WEBSOCKET_TIMEOUT_SECONDS=45
