# Central host network boundary. Keep loopback for a same-host dashboard.
# Set an explicit trusted LAN or VPN interface address only when remote access is required.
CENTRAL_BIND_ADDRESS=127.0.0.1
CENTRAL_API_PORT=8082
CENTRAL_MQTT_PORT=1884

# Versioned application image used by controlled rollout and rollback.
TELEMETRY_SERVICE_IMAGE=nexolab-telemetry-service:local

POSTGRES_DB=nexolab
POSTGRES_USER=nexolab
POSTGRES_PASSWORD=replace-with-a-long-random-secret

# Canonical edge-01 route. Must match infrastructure/compose/.env.edge.
MQTT_TOPIC=nexolab/telemetry
MQTT_CLIENT_ID=nexolab-central-telemetry-ingestion

# Comma-separated browser origins. Do not use * in the controlled profile.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ALLOW_CREDENTIALS=false

DATABASE_CONNECT_TIMEOUT_SECONDS=3
DATABASE_RETRY_INITIAL_SECONDS=0.25
DATABASE_RETRY_MAX_SECONDS=5
INGESTION_QUEUE_MAXSIZE=10000
INGESTION_PAYLOAD_MAX_BYTES=262144
DEAD_LETTER_PAYLOAD_MAX_BYTES=65536
API_MAX_PAGE_SIZE=1000
HISTORY_MAX_RANGE_DAYS=31
WEBSOCKET_CLIENT_QUEUE_MAXSIZE=256
WEBSOCKET_HEARTBEAT_SECONDS=20
WEBSOCKET_SEND_TIMEOUT_SECONDS=5
WEBSOCKET_RESUME_LIMIT=1000
RETENTION_ENABLED=true
TELEMETRY_RETENTION_DAYS=365
RAW_PAYLOAD_RETENTION_DAYS=30
DEAD_LETTER_RETENTION_DAYS=30
RETENTION_INTERVAL_SECONDS=3600
RETENTION_BATCH_SIZE=1000
