NEXOLAB_NODE_ID=edge-01
DEVICE_MODE=simulator
MQTT_TOPIC=nexolab/telemetry
SAMPLE_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
DEVICE_AGENT_IMAGE=ghcr.io/engine9r/nexolab-device-agent:edge

# Used only with compose.hardware.yaml after an explicit hardware cutover.
# Keep DEVICE_MODE=simulator so rollback requires only the base Compose file.
RS485_HOST_DEVICE=/dev/serial/by-id/usb-Silicon_Labs_CP2104_USB_to_UART_Bridge_Controller_0133F090-if00-port0
RS485_GROUP_GID=20
HARDWARE_DEVICE_MODE=modbus
XJP60D_POINTS=106:3,106:4
XJP60D_SCALE=0.1
LE01MP_UNIT_IDS=200,201,202,203
SERIAL_TIMEOUT_SECONDS=0.30
SERIAL_RETRIES=1
