# Use an immutable full-SHA image tag produced by telemetry-service-image.yml.
TELEMETRY_SERVICE_IMAGE=ghcr.io/engine9r/nexolab-telemetry-service:sha-REPLACE_WITH_FULL_COMMIT_SHA

POSTGRES_DB=nexolab
POSTGRES_USER=nexolab
POSTGRES_PASSWORD=replace-with-a-long-random-password

MQTT_USERNAME=nexolab-ingestion
MQTT_PASSWORD=replace-with-a-long-random-password
MQTT_TOPIC=nexolab/telemetry
MQTT_CLIENT_ID=nexolab-central-ingestion

# Keep both services local until private ingress and the Edge bridge are accepted.
BACKEND_API_BIND_ADDRESS=127.0.0.1
BACKEND_API_PORT=8082
BACKEND_MQTT_BIND_ADDRESS=127.0.0.1
BACKEND_MQTT_PORT=1884

# Comma-separated dashboard origins. Do not use '*'.
CORS_ALLOWED_ORIGINS=https://dashboard.example.invalid

DATABASE_CONNECT_TIMEOUT_SECONDS=3
DATABASE_RETRY_INITIAL_SECONDS=0.25
DATABASE_RETRY_MAX_SECONDS=5
INGESTION_QUEUE_MAXSIZE=10000
INGESTION_PAYLOAD_MAX_BYTES=262144
DEAD_LETTER_PAYLOAD_MAX_BYTES=65536
API_MAX_PAGE_SIZE=1000
HISTORY_MAX_RANGE_DAYS=31
WEBSOCKET_CLIENT_QUEUE_MAXSIZE=256
WEBSOCKET_HEARTBEAT_SECONDS=20
WEBSOCKET_SEND_TIMEOUT_SECONDS=5
WEBSOCKET_RESUME_LIMIT=1000
RETENTION_ENABLED=true
TELEMETRY_RETENTION_DAYS=365
RAW_PAYLOAD_RETENTION_DAYS=30
DEAD_LETTER_RETENTION_DAYS=30
RETENTION_INTERVAL_SECONDS=3600
RETENTION_BATCH_SIZE=1000
